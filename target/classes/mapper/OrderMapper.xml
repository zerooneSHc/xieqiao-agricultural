<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xieqiao.agricultural.dao.OrderDao">
    <select id="list" resultType="Order"> select * from `order` </select>
    <insert id="insert"> insert into `order`(order_no,user_id,product_id,num,total_price,status) values(#{orderNo},#{userId},#{productId},#{num},#{totalPrice},#{status}) </insert>
</mapper>