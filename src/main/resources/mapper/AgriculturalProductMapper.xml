<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xieqiao.agricultural.dao.AgriculturalProductDao">
    <select id="list" resultType="AgriculturalProduct"> select * from agricultural_product </select>
    <select id="getById" resultType="AgriculturalProduct"> select * from agricultural_product where id=#{id} </select>
    <insert id="insert"> insert into agricultural_product(product_name,category,price,stock,farmer_name,address,status) values(#{productName},#{category},#{price},#{stock},#{farmerName},#{address},#{status}) </insert>
    <update id="update"> update agricultural_product set product_name=#{productName},price=#{price},stock=#{stock} where id=#{id} </update>
    <delete id="delete"> delete from agricultural_product where id=#{id} </delete>
</mapper>